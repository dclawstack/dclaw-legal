# DClaw Legal Environment Variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql+asyncpg://legal:legal@localhost:5432/dclaw_legal

# AI Providers
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENROUTER_API_KEY=          # Required for cloud models

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8099
CORS_ORIGINS=http://localhost:3013
